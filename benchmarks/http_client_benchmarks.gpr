with "../httpclient.gpr";

project Http_Client_Benchmarks is
   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Main use ("benchmark_runner.adb");
   for Languages use ("Ada");

   package Linker is
      for Default_Switches ("Ada") use ("-lssl", "-lcrypto");
   end Linker;

   package Compiler is
      for Default_Switches ("Ada") use
        ("-gnat2022",
         "-gnata",
         "-gnatW8");
   end Compiler;
end Http_Client_Benchmarks;
