with "zlib";

library project HttpClient is
   for Source_Dirs use ("src", "src/c");
   for Object_Dir use "obj";
   for Library_Dir use "lib";
   for Library_Name use "httpclient";
   for Library_Kind use "static";
   for Languages use ("Ada", "C");
   --  OpenSSL bridge linking is supplied by applications/tests.

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022","-gnatyM120","-gnatX", "-gnata");
   end Compiler;
end HttpClient;
